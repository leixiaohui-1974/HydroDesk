{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "HydroDesk",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "all": false,
        "close": true,
        "minimize": true,
        "maximize": true,
        "unmaximize": true,
        "startDragging": true,
        "hide": true,
        "show": true
      },
      "shell": {
        "open": true
      },
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": ["$APPDATA/**", "$DOCUMENT/**", "$DOWNLOAD/**"]
      },
      "http": {
        "all": true,
        "request": true,
        "scope": [
          "http://localhost:8000/**",
          "http://localhost:8001/**",
          "http://localhost:8080/**",
          "http://localhost:9000/**",
          "http://localhost:9999/**",
          "http://localhost:11434/**",
          "http://127.0.0.1:*/**"
        ]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.hydromind.hydrodesk",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:*; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "HydroDesk - 水网桌面端",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "transparent": false,
        "center": true
      }
    ]
  }
}
